import { createUUID } from './utils/helpers.js';

// DOM elements
const noteList = document.getElementById('note-list');
const placeholder = document.getElementById('placeholder');
const noteContent = document.getElementById('note-content');
const shareModal = document.getElementById('share-modal');
const deleteModal = document.getElementById('delete-modal');
const closeShareBtn = document.getElementById('close-share');
const closeDeleteBtn = document.getElementById('close-delete');
const addNoteBtn = document.getElementById('add-note-btn');

let notes = [];

// Hiển thị danh sách ghi chú
function displayNoteList() {
  noteList.innerHTML = '';
  notes.forEach(note => {
    const li = document.createElement('li');
    li.textContent = note.title;
    li.addEventListener('click', () => displayNoteContent(note.id));
    noteList.appendChild(li);
  });
}

// Hiển thị nội dung ghi chú
function displayNoteContent(id) {
  const note = notes.find(n => n.id === id);
  if (note) {
    placeholder.style.display = 'none';
    noteContent.innerHTML = `<h3>${note.title}</h3><p>${note.content}</p>`;
  }
}

// Thêm ghi chú mới
function addNote() {
  const newNote = {
    id: createUUID(),
    title: 'Ghi chú mới',
    content: 'Nội dung ghi chú mới',
  };
  notes.push(newNote);
  displayNoteList();
}

// Đóng modal
function closeModal(modal) {
  modal.style.display = 'none';
}

// Event Listeners
addNoteBtn.addEventListener('click', addNote);
closeShareBtn.addEventListener('click', () => closeModal(shareModal));
closeDeleteBtn.addEventListener('click', () => closeModal(deleteModal));

// Khởi tạo
displayNoteList();
